#!/usr/bin/env bash
# =============================================================================
# TODO-script-name.sh
#
# TODO: Describe the user-facing operation this entrypoint performs and name
# the runbook/phase that invokes it.
#
# This file is intended for bin/. It should coordinate configuration,
# validation, helper invocation, user-facing output, and exit status. Keep
# detailed implementation logic in .internal/ helpers when practical.
#
# --- BEGIN USAGE ---
# Usage:
#   cd <repo-root>
#   chmod +x bin/TODO-script-name.sh
#
#   # Default run
#   ./bin/TODO-script-name.sh
#
#   # Override the artifact root for this invocation
#   ./bin/TODO-script-name.sh \
#     --artifact-root /Volumes/Data/reimage-<asset>-<date>-open
#
#   # Override the output directory
#   ./bin/TODO-script-name.sh --output-root /absolute/path/to/output
#
#   # Supply repeatable input roots when this operation needs them
#   ./bin/TODO-script-name.sh \
#     --input-root /absolute/path/one \
#     --input-root /absolute/path/two
#
#   # Open the primary output after completion
#   ./bin/TODO-script-name.sh --open
#
# Options:
#   --artifact-root PATH  Override REIMAGE_ARTIFACT_ROOT from shared config.
#   --output-root PATH    Override the operation-specific output directory.
#   --input-root PATH     Add an input root. Repeatable when applicable.
#   --open                Open the primary output in Finder after completion.
#   -h, --help            Show this message and exit.
#
# Configuration precedence:
#   1. Explicit command-line options for this invocation.
#   2. Environment values already exported by the caller or optional .envrc.
#   3. Values loaded from reimage.env.
#   4. Defaults and reusable fragments loaded by artifact-config.sh.
#
# Exit status:
#   0  Operation completed successfully.
#   1  Operation ran but encountered a workflow/runtime failure.
#   2  Usage, configuration, prerequisite, or dependency error.
# --- END USAGE ---
# =============================================================================

set -euo pipefail
# For aggregate checklist/report scripts only, use `set -uo pipefail` instead
# and explain why `set -e` is intentionally omitted. Do not omit `set -e`
# merely for consistency with a validator.

# ---------------------------------------------------------------------------
# Locate repository and load shared reimage config
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CONFIG_LOADER="$REPO_ROOT/.internal/load-reimage-config-snippet.sh"

if [[ ! -f "$CONFIG_LOADER" ]]; then
  echo "ERROR: shared config loader not found: $CONFIG_LOADER" >&2
  exit 2
fi

# Keep loading permissive so command-line options can override values after
# parsing. Set this to true only when this script must fail during config load.
ARTIFACT_CONFIG_REQUIRE_REIMAGE_ARTIFACT_ROOT=false

# shellcheck source=../.internal/load-reimage-config-snippet.sh
source "$CONFIG_LOADER"

SCRIPT_NAME="${REIMAGE_SCRIPT_DISPLAY_NAME:-TODO-script-name.sh}"

# ---------------------------------------------------------------------------
# Defaults and command-line state
# ---------------------------------------------------------------------------
OUTPUT_ROOT=""
OPEN_AFTER=false
INPUT_ROOTS=()

usage() {
  sed -n '/^# --- BEGIN USAGE ---$/,/^# --- END USAGE ---$/p' "$0" \
    | sed '1d;$d;s/^# //;s/^#$//'
}

require_option_value() {
  local option="$1"
  local value="${2:-}"

  if [[ -z "$value" || "$value" == --* ]]; then
    echo "ERROR: $option requires a non-empty value." >&2
    usage >&2
    exit 2
  fi
}

# ---------------------------------------------------------------------------
# Parse command-line options
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --artifact-root)
      require_option_value "$1" "${2:-}"
      REIMAGE_ARTIFACT_ROOT="$2"
      shift 2
      ;;
    --output-root)
      require_option_value "$1" "${2:-}"
      OUTPUT_ROOT="$2"
      shift 2
      ;;
    --input-root)
      require_option_value "$1" "${2:-}"
      INPUT_ROOTS+=("$2")
      shift 2
      ;;
    --open)
      OPEN_AFTER=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "ERROR: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

# ---------------------------------------------------------------------------
# Resolve configured defaults after command-line parsing
# ---------------------------------------------------------------------------
if [[ -z "${REIMAGE_ARTIFACT_ROOT:-}" ]]; then
  echo "ERROR: REIMAGE_ARTIFACT_ROOT is not set." >&2
  echo "Create/source reimage.env or pass --artifact-root PATH." >&2
  exit 2
fi

if [[ ! -d "$REIMAGE_ARTIFACT_ROOT" ]]; then
  echo "ERROR: artifact root not found: $REIMAGE_ARTIFACT_ROOT" >&2
  exit 2
fi

if [[ -z "$OUTPUT_ROOT" ]]; then
  # TODO: Replace TODO-output-subdir with the stable directory established by
  # the runbook. Do not introduce timestamping, latest pointers, or manifest
  # policy here until that operation's artifact strategy has been decided.
  OUTPUT_ROOT="$REIMAGE_ARTIFACT_ROOT/TODO-output-subdir"
fi

if [[ ${#INPUT_ROOTS[@]} -eq 0 ]]; then
  # TODO: Add only configuration-backed defaults that are meaningful for this
  # operation. Do not hardcode user-specific workspace paths.
  #
  # Example for Git-oriented entrypoints:
  # [[ -n "${GIT_WORK_REPO_ROOT:-}" ]] && INPUT_ROOTS+=("$GIT_WORK_REPO_ROOT")
  # [[ -n "${GIT_PERSONAL_REPO_ROOT:-}" ]] && INPUT_ROOTS+=("$GIT_PERSONAL_REPO_ROOT")
  :
fi

# ---------------------------------------------------------------------------
# Validate prerequisites and dependencies
# ---------------------------------------------------------------------------
for input_root in "${INPUT_ROOTS[@]}"; do
  if [[ ! -d "$input_root" ]]; then
    echo "ERROR: input root not found: $input_root" >&2
    exit 2
  fi
done

HELPER_SCRIPT="$REPO_ROOT/.internal/TODO/TODO-helper.sh"
if [[ ! -f "$HELPER_SCRIPT" ]]; then
  echo "ERROR: helper not found: $HELPER_SCRIPT" >&2
  exit 2
fi

# Add operation-specific command checks here.
# Example:
# if ! command -v git >/dev/null 2>&1; then
#   echo "ERROR: git is not installed or not on PATH." >&2
#   exit 2
# fi

# ---------------------------------------------------------------------------
# Execute operation
# ---------------------------------------------------------------------------
# Creating this operation's own output directory is acceptable when creation
# is part of the run. Validation-only scripts should not create directories
# they are supposed to verify.
mkdir -p "$OUTPUT_ROOT"

HELPER_ARGS=(--dest "$OUTPUT_ROOT")
for input_root in "${INPUT_ROOTS[@]}"; do
  HELPER_ARGS+=(--root "$input_root")
done

# Invoke with bash instead of changing executable bits at runtime. Script
# permissions should be committed correctly; a run should not dirty the repo.
bash "$HELPER_SCRIPT" "${HELPER_ARGS[@]}"

PRIMARY_OUTPUT="$OUTPUT_ROOT"

# ---------------------------------------------------------------------------
# Final summary
# ---------------------------------------------------------------------------
printf '\n%s completed.\n' "$SCRIPT_NAME"
printf 'Artifact root: %s\n' "$REIMAGE_ARTIFACT_ROOT"
printf 'Output:        %s\n' "$PRIMARY_OUTPUT"

if [[ "$OPEN_AFTER" == true ]]; then
  open "$PRIMARY_OUTPUT"
fi
