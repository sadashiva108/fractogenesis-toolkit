# reimage.env.example
# Template for fractogenesis-toolkit local config.
#
# Naming reflects the current design; the scripts that read these values
# (prepare-backup-root.py, backup-config.sh) have not been migrated here yet.
# Continue using reference-vault's reimage.env.example for your actual
# upcoming reimage until Phase 1 is migrated and verified in this repo.
#
# Copy this file to reimage.env, edit it for the current Mac, then keep
# reimage.env local/private.
#
# Commit this example file. Do not commit reimage.env.
#
# Important:
# - reimage.env should contain resolved values only.
# - Do not put shell expressions such as ${VAR:-...}, $HOME/..., or
#   EXTERNAL_DATA_VOLUME/... in reimage.env values.
# - Optional paths can stay blank until that workflow is used.
# - Replace /Users/<user>/... examples with the real absolute path on the Mac.
#
# Naming conventions used below:
# - _VOLUME  = a physical/mounted external volume (matches diskutil's own
#              vocabulary and the docs' existing "External Data Volume"
#              troubleshooting sections)
# - _ROOT    = the top of a generated tree with many child subfolders
#              (system-inventory/, performance-audit/, secrets-encrypted/, etc.)
# - _HOME    = where a piece of software/repo lives on disk, matching this
#              machine's existing shell convention (JAVA_HOME, GROOVY_HOME)

# -----------------------------------------------------------------------------
# Core reimage workflow paths
# -----------------------------------------------------------------------------

# REIMAGE_ROOT is intentionally REMOVED from this file. FRACTOGENESIS_HOME
# (below) replaces it, but lives in .envrc / shell startup, not here — once
# Phase 1 scripts self-locate (matching backup-config.sh's existing pattern),
# there's nothing left for a human to fill in in reimage.env for this.
# NOTE: prepare-backup-root.py currently reads REIMAGE_ROOT by name from this
# exact file (see its ENV_KEYS/PATH_KEYS lists) — needs a matching update
# during its own Phase 1 migration, or this removal will break it. Tracked,
# not done yet.

# Where fractogenesis-toolkit itself is currently checked out. Set via shell
# startup (.envrc, once Phase 1 lands) rather than here — listed for reference:
#   export FRACTOGENESIS_HOME="$HOME/reimage-toolkit"   # or your permanent clone location

# Parent external data/artifact volume — the physical/mounted volume only,
# not the specific event folder created on it (that's REIMAGE_ARTIFACT_ROOT,
# below).
export EXTERNAL_DATA_VOLUME="/Volumes/Data"

# Optional dedicated Time Machine destination volume.
export EXTERNAL_APPLE_BACKUPS_VOLUME=""

# Small dedicated jump drive used as the no-network bootstrap fallback.
# Separate concept from EXTERNAL_DATA_VOLUME/REIMAGE_ARTIFACT_ROOT — this is
# the fallback delivery mechanism for the toolkit itself, not where backup
# artifacts land. Same _VOLUME category as EXTERNAL_DATA_VOLUME (a physical
# mounted volume), not _ROOT (a generated tree).
export JUMP_DRIVE_VOLUME="/Volumes/REIMAGEKIT"

# Asset tag or hostname used in the artifact root name.
export ASSET_OR_HOST="<asset-or-host>"

# Date the reimage effort started, in YYYYMMDD format.
export REIMAGE_START_DATE="YYYYMMDD"

# Dedicated artifact root for this reimage event — backups, captures,
# secrets DMG, checklists, sign-off templates all live under here.
# (Formerly BACKUP_ROOT — renamed since it holds more than backups.)
# Leave blank when first creating reimage.env.
export REIMAGE_ARTIFACT_ROOT=""

# -----------------------------------------------------------------------------
# Optional workflow paths
# -----------------------------------------------------------------------------
export FRACTOGENESIS_HOME=""
export REIMAGE_WORKSPACE_ROOT=""
export IT_PLAN_DIR=""
export PERFORMANCE_HISTORY_SOURCE=""
export OFFICE_WATCH=""
export ONEDRIVE_FOLDER_NAME=""
export ONEDRIVE_ROOT=""
export ONEDRIVE_DEST_SUBDIR=""

# -----------------------------------------------------------------------------
# Git repository roots for backup-git-repository.md
# -----------------------------------------------------------------------------

export GIT_WORK_REPO_ROOT=""
export GIT_PERSONAL_REPO_ROOT=""

# -----------------------------------------------------------------------------
# Optional Git setup values
# -----------------------------------------------------------------------------

export GIT_WORK_NAME=""
export GIT_WORK_EMAIL=""
export GIT_PERSONAL_NAME=""
export GIT_PERSONAL_EMAIL=""
export GIT_WORK_GITHUB_HOST="github.com"
export GIT_PERSONAL_GITHUB_HOST="github-personal"
export GIT_WORK_SSH_KEY=""
export GIT_PERSONAL_SSH_KEY=""
export GIT_DEFAULT_BRANCH="master"
