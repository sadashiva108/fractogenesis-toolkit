#!/usr/bin/env bash
# =============================================================================
# TODO-helper.sh
#
# TODO: Describe the focused implementation task performed by this helper.
# Normally invoked by bin/TODO-entrypoint.sh, but may be run standalone when
# all required paths and options are passed explicitly.
#
# This file is intended for .internal/<domain>/. Keep it focused, deterministic,
# and parameter-driven. The bin/ entrypoint should own user-facing workflow
# coordination and normal shared-config resolution.
# Do not use this template verbatim for source-only foundation/config loaders;
# those must preserve caller shell state and must not behave like executables.
#
# --- BEGIN USAGE ---
# Usage:
#   cd <repo-root>
#
#   ./.internal/TODO/TODO-helper.sh \
#     --root /absolute/input/root \
#     --dest /absolute/output/root
#
#   ./.internal/TODO/TODO-helper.sh \
#     --root /absolute/input/root-one \
#     --root /absolute/input/root-two \
#     --dest /absolute/output/root \
#     --copy
#
# Options:
#   --root PATH       Input root. Repeatable.
#   --dest PATH       Destination for reports or copied output.
#   --copy            Perform the mutating/copy operation.
#                     Without this flag, perform a durable dry run.
#   --include-heavy   Include generated/heavy content when supported.
#   -h, --help        Show this message and exit.
#
# Configuration:
#   Shared reimage config is intentionally NOT loaded by default. The caller
#   passes resolved paths explicitly. Add shared loading only when standalone
#   use has a real, documented need for configuration-backed defaults.
#
# Exit status:
#   0  Helper completed successfully.
#   1  Runtime or copy failure.
#   2  Usage, prerequisite, or dependency error.
# --- END USAGE ---
# =============================================================================

set -euo pipefail

# ---------------------------------------------------------------------------
# Locate helper context
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Adjust the number of parent traversals for the actual helper location.
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

# Do not source .envrc. It is an optional interactive convenience only.
# Do not source reimage.env directly from a pure helper.

# ---------------------------------------------------------------------------
# Defaults and command-line state
# ---------------------------------------------------------------------------
ROOTS=()
DEST=""
DO_COPY=false
INCLUDE_HEAVY=false

usage() {
  sed -n '/^# --- BEGIN USAGE ---$/,/^# --- END USAGE ---$/p' "$0" \
    | sed '1d;$d;s/^# //;s/^#$//'
}

require_option_value() {
  local option="$1"
  local value="${2:-}"

  if [[ -z "$value" || "$value" == --* ]]; then
    echo "ERROR: $option requires a non-empty value." >&2
    usage >&2
    exit 2
  fi
}

# ---------------------------------------------------------------------------
# Parse command-line options
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --root)
      require_option_value "$1" "${2:-}"
      ROOTS+=("$2")
      shift 2
      ;;
    --dest)
      require_option_value "$1" "${2:-}"
      DEST="$2"
      shift 2
      ;;
    --copy)
      DO_COPY=true
      shift
      ;;
    --include-heavy)
      INCLUDE_HEAVY=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "ERROR: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

# ---------------------------------------------------------------------------
# Validate arguments and prerequisites
# ---------------------------------------------------------------------------
if [[ ${#ROOTS[@]} -eq 0 ]]; then
  echo "ERROR: at least one --root PATH is required." >&2
  exit 2
fi

if [[ -z "$DEST" ]]; then
  echo "ERROR: --dest PATH is required." >&2
  exit 2
fi

for root in "${ROOTS[@]}"; do
  if [[ ! -d "$root" ]]; then
    echo "ERROR: root directory not found: $root" >&2
    exit 2
  fi
done

# Add focused dependency checks here.
# Example:
# if ! command -v git >/dev/null 2>&1; then
#   echo "ERROR: git is not installed or not on PATH." >&2
#   exit 2
# fi

# A durable dry run normally needs an output location too. Whether DEST is a
# stable directory, timestamped run directory, or another layout is a
# workflow-level decision; do not invent that policy inside the helper.
mkdir -p "$DEST"

# ---------------------------------------------------------------------------
# Helper functions
# ---------------------------------------------------------------------------
should_skip_path() {
  local relative_path="$1"

  [[ "$INCLUDE_HEAVY" == true ]] && return 1

  case "$relative_path" in
    node_modules/*|*/node_modules/*) return 0 ;;
    .gradle/*|*/.gradle/*) return 0 ;;
    target/*|*/target/*) return 0 ;;
    build/*|*/build/*) return 0 ;;
    dist/*|*/dist/*) return 0 ;;
    out/*|*/out/*) return 0 ;;
    .venv/*|*/.venv/*) return 0 ;;
    venv/*|*/venv/*) return 0 ;;
    __pycache__/*|*/__pycache__/*) return 0 ;;
  esac

  return 1
}

process_root() {
  local root="$1"

  # TODO: Implement focused discovery and processing.
  #
  # Portability requirements:
  # - Remain compatible with the stock macOS Bash 3.2 unless the script
  #   explicitly checks for a newer Bash.
  # - Do not use mapfile/readarray or associative arrays.
  # - Prefer NUL-delimited traversal when filenames may contain whitespace.
  # - In copy mode, continue safely for expected disappearing/generated files
  #   only when the runbook defines that behavior and the skip is recorded.
  printf 'TODO: process root: %s\n' "$root"
}

# ---------------------------------------------------------------------------
# Execute focused work
# ---------------------------------------------------------------------------
printf 'Mode:        %s\n' "$([[ "$DO_COPY" == true ]] && printf COPY || printf 'DRY RUN')"
printf 'Destination: %s\n' "$DEST"
printf 'Roots:\n'
for root in "${ROOTS[@]}"; do
  printf '  - %s\n' "$root"
done
printf '\n'

for root in "${ROOTS[@]}"; do
  process_root "$root"
done

# ---------------------------------------------------------------------------
# Final summary
# ---------------------------------------------------------------------------
printf '\nHelper completed.\n'
printf 'Mode:   %s\n' "$([[ "$DO_COPY" == true ]] && printf COPY || printf 'DRY RUN')"
printf 'Output: %s\n' "$DEST"
